# Anthropic — chave para o Scan Cadarn (IA conversacional)
ANTHROPIC_API_KEY=sk-ant-...

# Supabase — URL pública do projeto (exposta ao browser)
PUBLIC_SUPABASE_URL=https://<project-id>.supabase.co

# Supabase — chave anônima (exposta ao browser, segura com RLS ativo)
PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Supabase — service role key (NUNCA expor ao browser; usada apenas em API routes)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Pepper para pseudonimização de IP via HMAC-SHA256 (mínimo 32 chars aleatórios)
# Gerar com: openssl rand -hex 32
IP_HASH_PEPPER=<pepper-aleatorio-minimo-32-chars>
