---
/**
 * HeroV2 — hero dark premium "sala de comando a meia-luz".
 * GrainyBackground + HeadlineReveal (serifa oversize) + MagneticButton.
 * Bussola decorativa de fundo (logo-splash) com halo caramelo unico.
 */
import GrainyBackground from './GrainyBackground.astro';
import { HeadlineReveal } from './HeadlineReveal';
import { MagneticButton } from './MagneticButton';
import { BorderDrawButton } from './BorderDrawButton';

const HERO_LINES = ['Do caos ao método.', 'Do método ao lucro.', 'Do lucro à liberdade.'];
---

<section id="hero" class="relative overflow-hidden">
  <GrainyBackground variant="hero" />

  <!-- Bussola decorativa + halo caramelo unico (pointer:fine apenas o brilho intenso) -->
  <div class="pointer-events-none absolute right-0 top-1/2 -translate-y-1/2 translate-x-1/4" aria-hidden="true">
    <div class="absolute left-1/2 top-1/2 h-[420px] w-[420px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-accent-metal/10 blur-[120px]"></div>
    <img src="/logo-splash.png" alt="" class="h-[520px] w-[520px] opacity-[0.05]" aria-hidden="true" />
  </div>

  <div class="relative z-10 mx-auto flex min-h-[92vh] max-w-content flex-col justify-center px-4 py-24 sm:px-6 lg:px-8">
    <p class="font-body text-xs uppercase tracking-[0.4em] text-accent-metal">
      Engenharia de Lucro
    </p>

    <div class="mt-6 max-w-4xl">
      <HeadlineReveal client:load lines={HERO_LINES} />
    </div>

    <p class="mt-8 max-w-xl font-body text-lg leading-relaxed text-on-dark-body">
      Marketing, gestão e growth integrados num sistema único para prestadores de serviço premium.
    </p>

    <div class="mt-12 flex flex-wrap items-center gap-5">
      <MagneticButton client:visible href="/scan">
        Faça seu Scan de Autoridade
      </MagneticButton>
      <BorderDrawButton client:visible href="/metodo">
        Conheça o Método
      </BorderDrawButton>
    </div>
  </div>
</section>
