---
const currentYear = new Date().getFullYear();
---

<footer class="bg-navy py-8">
  <div class="mx-auto max-w-content px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col items-center justify-between gap-4 sm:flex-row">
      <a href="/" class="font-headline text-sm font-bold uppercase tracking-[0.3em] text-offwhite">
        Cadarn
      </a>

      <div class="flex items-center gap-6 text-sm text-offwhite/60">
        <a href="https://www.instagram.com/cadarnmartech/" target="_blank" rel="noopener noreferrer" class="transition-colors hover:text-caramelo" aria-label="Instagram Cadarn Martech">
          Instagram
        </a>
        <a href="/privacidade" class="transition-colors hover:text-caramelo">Privacidade</a>
        <a href="/termos" class="transition-colors hover:text-caramelo">Termos</a>
        <a href="mailto:contato@cadarn.com.br" class="transition-colors hover:text-caramelo">
          contato@cadarn.com.br
        </a>
      </div>

      <span class="text-sm text-offwhite/40">© {currentYear} Cadarn Martech</span>
    </div>
  </div>
</footer>
