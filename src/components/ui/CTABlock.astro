---
import { Button } from './Button';

interface Props {
  variant?: 'hero' | 'inline' | 'sticky';
  href?: string;
  text?: string;
  class?: string;
}

const {
  variant = 'inline',
  href = '/scan',
  text = 'Faça seu Scan de Autoridade',
  class: className,
} = Astro.props;

const wrapperClasses: Record<string, string> = {
  hero: 'py-8 text-center',
  inline: 'py-6',
  sticky: 'fixed bottom-0 left-0 right-0 z-50 bg-navy/95 backdrop-blur-sm py-3 px-4 text-center',
};

const buttonSize: Record<string, 'sm' | 'md' | 'lg'> = {
  hero: 'lg',
  inline: 'md',
  sticky: 'sm',
};
---

<div class:list={[wrapperClasses[variant], className]}>
  <Button href={href} variant="secondary" size={buttonSize[variant]}>
    {text}
  </Button>
  {variant === 'hero' && (
    <p class="mt-3 text-sm opacity-70">Grátis · 5 minutos · Sem compromisso</p>
  )}
</div>
