---
interface Props {
  label?: string;
  class?: string;
}

const { label = 'Vídeo Samira — 30-60s', class: className } = Astro.props;
---

<div class:list={['relative mx-auto max-w-4xl overflow-hidden bg-navy/5', className]}>
  <div class="aspect-video relative flex items-center justify-center bg-navy">
    {/* Grid tech de fundo */}
    <div class="absolute inset-0 opacity-[0.04]"
      style={{
        backgroundImage: `
          linear-gradient(rgba(154,122,81,0.4) 1px, transparent 1px),
          linear-gradient(90deg, rgba(154,122,81,0.4) 1px, transparent 1px)
        `,
        backgroundSize: '40px 40px',
      }}
    />
    {/* Play button */}
    <div class="relative z-10 flex flex-col items-center gap-4">
      <div class="glow-caramelo flex h-20 w-20 items-center justify-center border-2 border-caramelo/50 rounded-full transition-all duration-300 hover:border-caramelo hover:scale-110">
        <svg class="ml-1 h-8 w-8 text-caramelo" fill="currentColor" viewBox="0 0 24 24">
          <path d="M8 5v14l11-7z" />
        </svg>
      </div>
      <span class="font-mono text-sm uppercase tracking-widest text-offwhite/70">🎬 {label}</span>
    </div>
    {/* Bússola decorativa */}
    <div class="pointer-events-none absolute right-8 bottom-8 opacity-[0.06]">
      <img src="/logo-splash.png" alt="" class="h-24 w-24" aria-hidden="true" />
    </div>
  </div>
</div>
