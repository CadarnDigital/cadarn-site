---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionWrapper from '../../components/ui/SectionWrapper.astro';
import CTABlock from '../../components/ui/CTABlock.astro';
---

<BaseLayout title="História" description="A gênese da Cadarn Martech em 6 capítulos — do batismo de fogo à pedra fundamental da Engenharia de Lucro para prestadores de serviço premium.">
  <SectionWrapper variant="dark">
    <h1 class="font-headline text-4xl font-bold lg:text-5xl">Nossa História</h1>
    <p class="mt-4 text-offwhite/70">Em desenvolvimento — Epic 2</p>
  </SectionWrapper>

  <CTABlock variant="sticky" />
</BaseLayout>
