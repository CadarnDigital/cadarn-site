---
/**
 * Home V2 — "premium tech" / "sala de comando a meia-luz" em VINHO.
 * Identidade: VINHO = cor dominante de peso; NAVY = apoio operacional;
 * OFFWHITE = base quente de respiro; caramelo = acento fino.
 * Conteudo textual IDENTICO a v1 (src/pages/index.astro).
 * Ritmo: Hero(vinho) -> numeros(navy/apoio operacional) -> dor(offwhite respiro)
 * -> citacao(vinho) -> triade(vinho) -> prova(vinho) -> blog(offwhite respiro)
 * -> CTA(vinho) -> newsletter(vinho).
 * Pagina de validacao — noindex via BaseLayoutV2.
 */
import { getCollection } from 'astro:content';
import BaseLayoutV2 from '../../layouts/BaseLayoutV2.astro';
import HeroV2 from '../../components/v2/HeroV2.astro';
import GrainyBackground from '../../components/v2/GrainyBackground.astro';
import { CurtainIntro } from '../../components/v2/CurtainIntro';
import { MagneticButton } from '../../components/v2/MagneticButton';
import { SpotlightCard } from '../../components/v2/SpotlightCard';
import Badge from '../../components/ui/Badge.astro';

const numeros = [
  { valor: '6', label: 'etapas proprietárias' },
  { valor: '7', label: 'dias para o diagnóstico' },
  { valor: '4', label: 'pilares de análise' },
];

const dores = [
  { titulo: 'Investe e não sabe o que volta', desc: 'Tráfego, postagens, agência — e nenhuma métrica real de retorno.' },
  { titulo: 'Depende de indicação', desc: 'Cresce quando indica. Para quando não. Zero previsibilidade.' },
  { titulo: 'Faz tudo sozinho', desc: 'Marketing, vendas, operação — você é o gargalo do próprio negócio.' },
];

const triade = [
  { pilar: 'Marketing', desc: 'Autoridade que gera demanda qualificada.' },
  { pilar: 'Gestão', desc: 'Processos que geram previsibilidade.' },
  { pilar: 'Growth', desc: 'Funil que gera escala mensurável.' },
];

const provas = [
  { valor: '98%', desc: 'dos donos de PME decidem sozinhos em 4+ áreas', fonte: 'Locomotiva/Itaú 2024' },
  { valor: '74%', desc: 'do orçamento de marketing vai para curto prazo', fonte: 'Conversion 2025' },
  { valor: '96%', desc: 'ainda executam tarefas operacionais no dia a dia', fonte: 'Locomotiva/Itaú 2024' },
];

const cases = ['Clínica Premium', 'Imobiliária Alto Padrão', 'Escritório de Advocacia', 'Contabilidade Digital'];

const allPosts = await getCollection('blog');
const blogHighlights = allPosts
  .sort((a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime())
  .slice(0, 3);
---

<BaseLayoutV2 title="Home" description="Cadarn Martech — Engenharia de Lucro para prestadores de serviço premium. Marketing, gestão e growth integrados num sistema único.">

  <CurtainIntro client:load />

  <!-- ═══ HERO ═══ -->
  <HeroV2 />

  <!-- ═══ NÚMEROS — faixa operacional/controle (NAVY = cor de apoio) ═══ -->
  <section class="relative overflow-hidden border-y border-accent-metal/15 bg-surface-navy">
    <GrainyBackground variant="navy" />
    <div class="relative z-10 mx-auto flex max-w-content flex-col items-center justify-center gap-10 px-4 py-12 sm:flex-row sm:gap-16 lg:gap-28 lg:py-14">
      {numeros.map((n) => (
        <div class="reveal-on-scroll text-center">
          <span class="mx-auto mb-3 block h-px w-8 bg-accent-metal"></span>
          <span class="font-accent text-6xl italic text-on-dark-strong lg:text-7xl">{n.valor}</span>
          <p class="mt-2 font-body text-xs uppercase tracking-widest text-on-dark-muted">{n.label}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ═══ DOR — seção light de respiro ═══ -->
  <section id="dor" class="bg-offwhite py-16 text-vinho lg:py-28">
    <div class="mx-auto max-w-content px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 items-start gap-12 lg:grid-cols-2">
        <div class="reveal-on-scroll lg:sticky lg:top-24">
          <p class="font-body text-sm uppercase tracking-widest text-caramelo">Soa familiar?</p>
          <h2 class="mt-3 font-headline text-3xl font-bold leading-tight lg:text-4xl">
            Você trabalha mais<br />do que deveria.<br />
            E lucra menos<br />do que <span class="font-accent italic text-caramelo">merece.</span>
          </h2>
        </div>
        <div class="space-y-6">
          {dores.map((dor, i) => (
            <div class:list={[
              'reveal-on-scroll border-l-2 border-vinho/20 pl-6 transition-colors duration-200 hover:border-caramelo',
              i === 1 && 'lg:ml-8',
              i === 2 && 'lg:ml-16',
            ]}>
              <h3 class="font-headline text-xl font-bold">{dor.titulo}</h3>
              <p class="mt-1 font-body text-vinho/60">{dor.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ CITAÇÃO — fullbleed vinho ═══ -->
  <section class="relative overflow-hidden bg-surface-vinho py-20 lg:py-28">
    <GrainyBackground variant="vinho" />
    <div class="relative z-10 mx-auto max-w-content px-4 sm:px-6 lg:px-8">
      <div class="flex items-center gap-8 lg:gap-16">
        <span aria-hidden="true" class="hidden shrink-0 font-accent text-[12rem] italic leading-none text-accent-metal/10 lg:block">M</span>
        <blockquote class="reveal-on-scroll">
          <p class="font-accent text-2xl italic leading-relaxed text-on-dark-body lg:text-4xl">
            "Não é sobre fazer mais marketing.<br />
            É sobre fazer o marketing <span class="text-accent-metal-hi">certo.</span>"
          </p>
        </blockquote>
      </div>
    </div>
  </section>

  <!-- ═══ TRÍADE — dark ═══ -->
  <section id="triade" class="relative overflow-hidden bg-surface-base py-16 lg:py-28">
    <GrainyBackground variant="hero" />
    <div class="relative z-10 mx-auto max-w-content px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl">
        <p class="font-body text-sm uppercase tracking-widest text-accent-metal">A solução</p>
        <h2 class="reveal-on-scroll mt-3 font-accent text-4xl italic text-on-dark-strong lg:text-5xl">
          Três pilares. Um sistema.
        </h2>
      </div>
      <div class="mt-12 grid grid-cols-1 gap-6 md:grid-cols-3">
        {triade.map((item) => (
          <SpotlightCard client:visible className="reveal-on-scroll border-l-2 border-accent-metal/40 bg-surface-raised/40 p-8 shadow-dark-md transition-colors duration-300 hover:border-accent-metal">
            <h3 class="relative z-10 font-headline text-xl font-bold uppercase tracking-wide text-on-dark-strong">{item.pilar}</h3>
            <p class="relative z-10 mt-3 font-body text-on-dark-body">{item.desc}</p>
          </SpotlightCard>
        ))}
      </div>
      <div class="mt-12">
        <a
          href="/metodo"
          class="link-underline font-headline text-sm uppercase tracking-widest text-on-dark-muted transition-colors duration-200 hover:text-on-dark-strong"
        >
          Conheça o Método C.A.D.A.R.N.
        </a>
      </div>
    </div>
  </section>

  <!-- ═══ PROVA — dark, números-selo + cases ═══ -->
  <section id="prova" class="relative overflow-hidden border-t border-accent-metal/15 bg-surface-abyss py-16 lg:py-28">
    <div class="relative z-10 mx-auto max-w-content px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 items-center gap-12 lg:grid-cols-5">
        <div class="lg:col-span-2">
          <p class="font-body text-sm uppercase tracking-widest text-accent-metal">O problema é real</p>
          <h2 class="reveal-on-scroll mt-3 font-headline text-3xl font-bold text-on-dark-strong lg:text-4xl">
            O dono faz tudo.<br />O marketing não faz nada.
          </h2>
          <div class="mt-10 space-y-8">
            {provas.map((p) => (
              <div class="reveal-on-scroll">
                <span class="mb-2 block h-px w-8 bg-accent-metal"></span>
                <span class="font-accent text-5xl italic text-on-dark-strong">{p.valor}</span>
                <p class="mt-1 font-body text-sm text-on-dark-muted">{p.desc}</p>
                <p class="mt-0.5 font-body text-[10px] text-on-dark-muted/60">{p.fonte}</p>
              </div>
            ))}
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4 lg:col-span-3">
          {cases.map((name) => (
            <SpotlightCard client:visible className="clip-reveal-trigger reveal-on-scroll relative aspect-[4/3] overflow-hidden border border-accent-metal/10 bg-surface-raised/40">
              {/* overlay caramelo que se revela por clip-path no hover */}
              <div class="clip-reveal pointer-events-none absolute inset-0 z-[1] bg-gradient-to-br from-accent-metal/15 to-transparent" aria-hidden="true"></div>
              <div class="absolute inset-0 z-[2] flex flex-col justify-end bg-gradient-to-t from-surface-abyss/95 via-surface-abyss/40 to-transparent p-5">
                <p class="font-headline text-sm font-bold text-on-dark-strong">{name}</p>
                <p class="mt-1 text-xs text-accent-metal">Case em preparação</p>
              </div>
            </SpotlightCard>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ BLOG — seção light curta ═══ -->
  <section id="blog" class="bg-offwhite py-16 text-vinho lg:py-28">
    <div class="mx-auto max-w-content px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 items-start gap-12 lg:grid-cols-3">
        <div class="lg:col-span-1">
          <p class="font-body text-sm uppercase tracking-widest text-caramelo">Blog</p>
          <h2 class="reveal-on-scroll mt-3 font-headline text-3xl font-bold lg:text-4xl">
            Conteúdo que separa quem sabe de quem <span class="font-accent italic text-caramelo">acha</span> que sabe.
          </h2>
          <a href="/blog" class="link-underline mt-6 inline-block font-headline text-sm uppercase tracking-widest text-vinho transition-colors duration-200 hover:text-caramelo">
            Ver todos
          </a>
        </div>
        <div class="grid grid-cols-1 gap-6 lg:col-span-2 sm:grid-cols-2">
          {blogHighlights.length > 0 ? (
            blogHighlights.map((post, i) => (
              <a href={`/blog/${post.id}`} class:list={['reveal-on-scroll group block', i === 0 && 'sm:col-span-2']}>
                <article class="h-full border border-vinho/10 bg-offwhite p-5 shadow-card transition-shadow duration-200 hover:shadow-card-hover">
                  <Badge category={post.data.category} />
                  <h3 class="mt-3 font-headline text-lg font-bold text-vinho transition-colors duration-200 group-hover:text-caramelo">{post.data.title}</h3>
                  <p class="mt-2 text-sm text-navy/70">{post.data.description}</p>
                </article>
              </a>
            ))
          ) : (
            <div class="py-8 text-center sm:col-span-2">
              <p class="font-body text-vinho/60">Artigos em preparação.</p>
            </div>
          )}
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ CTA FINAL — dark ═══ -->
  <section class="relative overflow-hidden bg-surface-base py-20 lg:py-28">
    <GrainyBackground variant="hero" />
    <div class="relative z-10 mx-auto max-w-content px-4 text-center sm:px-6 lg:px-8">
      <h2 class="reveal-on-scroll font-accent text-4xl italic text-on-dark-strong lg:text-5xl">
        Pronto para sair do <span class="text-accent-metal-hi">achismo?</span>
      </h2>
      <p class="reveal-on-scroll mx-auto mt-5 max-w-xl font-body text-lg text-on-dark-body">
        O Scan de Autoridade analisa seu marketing em 4 pilares e entrega um diagnóstico com score de 0 a 100.
      </p>
      <div class="mt-10 flex flex-col items-center gap-3">
        <MagneticButton client:visible href="/scan">
          Faça seu Scan de Autoridade
        </MagneticButton>
        <p class="font-body text-sm text-on-dark-muted">Grátis · 5 minutos · Sem compromisso</p>
      </div>
    </div>
  </section>

  <!-- ═══ NEWSLETTER ═══ -->
  <section class="border-t border-accent-metal/15 bg-surface-abyss py-16 lg:py-20">
    <div class="mx-auto max-w-article px-4 text-center">
      <h3 class="font-headline text-2xl font-bold text-on-dark-strong lg:text-3xl">
        Conteúdo que separa quem sabe de quem acha que sabe.
      </h3>
      <p class="mt-3 font-body text-on-dark-body">
        Direto na caixa. Sem spam, sem enrolação.
      </p>
      <form id="newsletter-form-v2" class="mt-6 flex flex-col items-center gap-3 sm:flex-row sm:justify-center">
        <input
          type="email"
          name="email"
          placeholder="seu@email.com"
          required
          class="w-full rounded-none border border-accent-metal/30 bg-surface-raised/40 px-4 py-3 font-body text-on-dark-strong placeholder:text-on-dark-muted focus:border-accent-metal focus:outline-none focus:ring-1 focus:ring-accent-metal sm:max-w-xs"
        />
        <button
          type="submit"
          class="rounded-none bg-gradient-to-br from-accent-metal-hi to-accent-metal px-6 py-3 font-headline font-semibold uppercase tracking-wider text-surface-abyss transition-shadow duration-300 hover:shadow-glow"
        >
          Quero receber
        </button>
      </form>
      <p id="newsletter-feedback-v2" class="mt-3 hidden font-body text-sm text-on-dark-muted"></p>
    </div>
  </section>

  <script>
    const form = document.getElementById('newsletter-form-v2') as HTMLFormElement | null;
    const feedback = document.getElementById('newsletter-feedback-v2');

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = (form.elements.namedItem('email') as HTMLInputElement)?.value;

      try {
        const res = await fetch('/api/newsletter/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email }),
        });

        if (feedback) {
          feedback.textContent = res.ok
            ? 'Inscrição confirmada. Até a próxima edição.'
            : 'Algo deu errado. Tente novamente.';
          feedback.classList.remove('hidden');
        }

        if (res.ok) form.reset();
      } catch {
        if (feedback) {
          feedback.textContent = 'Algo deu errado. Tente novamente.';
          feedback.classList.remove('hidden');
        }
      }
    });
  </script>
</BaseLayoutV2>
