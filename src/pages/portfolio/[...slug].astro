---
import { getCollection, render } from 'astro:content';
import CaseLayout from '../../layouts/CaseLayout.astro';
import SectionWrapper from '../../components/ui/SectionWrapper.astro';
import PhotoPlaceholder from '../../components/ui/PhotoPlaceholder.astro';

export async function getStaticPaths() {
  const cases = await getCollection('portfolio');
  return cases.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const allCases = await getCollection('portfolio');
const relatedCases = allCases
  .filter((c) => c.id !== entry.id && c.data.segment === entry.data.segment)
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())
  .slice(0, 2);

const segmentLabels: Record<string, string> = {
  imobiliaria: 'Imobiliária',
  estetica: 'Estética',
  advocacia: 'Advocacia',
  arquitetura: 'Arquitetura',
  contabilidade: 'Contabilidade',
  outro: 'Outro',
};
---

<CaseLayout
  title={entry.data.title}
  client={entry.data.client}
  segment={entry.data.segment}
  description={entry.data.description}
  metrics={entry.data.metrics}
  heroImage={entry.data.heroImage}
  publishedAt={entry.data.publishedAt}
>
  <Content />

  <Fragment slot="related">
    {relatedCases.length > 0 && (
      <SectionWrapper variant="light" class="!py-16 lg:!py-20">
        <p class="font-body text-sm uppercase tracking-widest text-caramelo">Cases relacionados</p>
        <h3 class="mt-3 font-headline text-2xl font-bold lg:text-3xl">
          Mais resultados em {segmentLabels[entry.data.segment] ?? entry.data.segment}
        </h3>
        <div class="mt-10 grid grid-cols-1 gap-6 md:grid-cols-2">
          {relatedCases.map((relatedCase) => {
            const firstMetric = relatedCase.data.metrics?.[0];
            return (
              <a
                href={`/portfolio/${relatedCase.id}`}
                class="group relative aspect-[16/9] overflow-hidden rounded-none block"
              >
                <div class="absolute inset-0 grayscale transition-all duration-500 group-hover:grayscale-0">
                  {relatedCase.data.heroImage ? (
                    <img
                      src={relatedCase.data.heroImage}
                      alt={relatedCase.data.client}
                      class="h-full w-full object-cover"
                    />
                  ) : (
                    <PhotoPlaceholder label={relatedCase.data.client} aspect="landscape" class="h-full w-full" />
                  )}
                </div>
                <div class="absolute inset-0 bg-gradient-to-t from-navy/90 via-navy/40 to-transparent" />
                <div class="absolute bottom-0 left-0 right-0 p-6">
                  <span class="font-body text-xs uppercase tracking-widest text-caramelo">
                    {segmentLabels[relatedCase.data.segment]}
                  </span>
                  <h4 class="mt-1 font-headline text-lg font-bold text-offwhite">
                    {relatedCase.data.client}
                  </h4>
                  {firstMetric && (
                    <div class="mt-2 flex items-baseline gap-2">
                      <span class="font-headline text-2xl font-bold text-caramelo">{firstMetric.value}</span>
                      <span class="font-body text-xs text-offwhite/50">{firstMetric.label}</span>
                    </div>
                  )}
                </div>
              </a>
            );
          })}
        </div>
      </SectionWrapper>
    )}
  </Fragment>
</CaseLayout>
