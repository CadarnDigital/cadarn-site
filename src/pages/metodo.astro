---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionWrapper from '../components/ui/SectionWrapper.astro';
import { Button } from '../components/ui/Button';
import CTABlock from '../components/ui/CTABlock.astro';
import OversizedText from '../components/ui/OversizedText.astro';
import Divider from '../components/ui/Divider.astro';
import PhotoPlaceholder from '../components/ui/PhotoPlaceholder.astro';

const etapas = [
  { letra: 'C', nome: 'Clareza', sub: 'Scan de Vulnerabilidade', frase: 'Não se gerencia o que não se vê.', desc: 'Mapeamos cada sangria, cada ponto cego, cada risco invisível que drena seu faturamento.' },
  { letra: 'A', nome: 'Arquitetura', sub: 'Blueprint Tático', frase: 'Desenhar antes de gastar.', desc: 'Processo, funil, DNA da marca — tudo documentado antes de investir um centavo em tráfego.' },
  { letra: 'D', nome: 'Dados & DNA', sub: 'Validação + Identidade', frase: 'Testar antes de escalar.', desc: 'Dados validam a estratégia. DNA codifica seu tom e estética. Juntos, são blindagem.' },
  { letra: 'A', nome: 'Ação', sub: 'Ofensiva Sincronizada', frase: 'Mão na massa com precisão.', desc: 'Cronograma preciso, territórios definidos, execução sem margem para improviso.' },
  { letra: 'R', nome: 'Rastreio', sub: 'Tribunal do ROI', frase: 'Se não gera receita, não conta.', desc: 'Foco: faturamento e leads qualificados reais. Jamais métricas de vaidade.' },
  { letra: 'N', nome: 'Norma', sub: 'Lei de Ouro', frase: 'Se funcionou, vira lei.', desc: 'O dono sai da operação, o processo fica. Autonomia real.' },
];

const valores = [
  { nome: 'Verdade Radical', mantra: 'A verdade dura que enriquece.' },
  { nome: 'Arquitetura Evolutiva', mantra: 'Simplificar para gerar lucro.' },
  { nome: 'Blindagem de Risco', mantra: 'Dados e blindagem, não sorte.' },
  { nome: 'Padrão Cirúrgico', mantra: 'O necessário para ser o #1.' },
  { nome: 'Lei da Autonomia', mantra: 'Forjamos comandantes, não dependentes.' },
  { nome: 'Pacto de Trincheira', mantra: 'Garantir o legado, não a transação.' },
];

const diferenciais = [
  { aspecto: 'Método', mercado: 'Pacotes de posts', cadarn: 'Engenharia de Receita' },
  { aspecto: 'Velocidade', mercado: 'Meses estudando', cadarn: 'Inteligência em 10 dias' },
  { aspecto: 'Autonomia', mercado: 'Mensalidade eterna', cadarn: 'Forja Comandantes' },
  { aspecto: 'Terreno', mercado: 'Curtidas', cadarn: 'CRM + autoridade' },
  { aspecto: 'Métricas', mercado: 'Relatórios de alcance', cadarn: 'ROI e leads reais' },
  { aspecto: 'Estética', mercado: 'Design "Carnaval"', cadarn: 'Hermès Tech' },
];
---

<BaseLayout title="Método" description="Método C.A.D.A.R.N. — 6 etapas de Engenharia de Receita para prestadores de serviço premium">

  <!-- ═══ HERO — Fullbleed com tipografia grande ═══ -->
  <SectionWrapper variant="dark" class="!py-0">
    <div class="flex min-h-[70vh] flex-col justify-center py-16 lg:py-24">
      <p class="font-body text-xs uppercase tracking-[0.3em] text-caramelo">O framework proprietário</p>
      <h1 class="mt-4 font-headline text-5xl font-bold leading-[1.05] lg:text-7xl xl:text-8xl">
        <span class="text-caramelo">C.</span>A.<span class="text-caramelo">D.</span>A.<span class="text-caramelo">R.</span>N.
      </h1>
      <p class="mt-6 max-w-lg font-body text-lg text-offwhite/60">
        6 etapas. Espiral ascendente. Do diagnóstico à autonomia — sem atalho, sem achismo.
      </p>
    </div>
    <!-- Bússola decorativa -->
    <div class="pointer-events-none absolute bottom-0 right-0 translate-x-1/4 translate-y-1/4 opacity-[0.03]">
      <img src="/logo-splash.png" alt="" class="h-[500px] w-[500px]" aria-hidden="true" />
    </div>
  </SectionWrapper>

  <!-- ═══ AS 6 ETAPAS — Alternância split esquerda/direita ═══ -->
  {etapas.map((etapa, i) => (
    <Fragment>
      {i === 3 && <Divider />}
      <SectionWrapper variant={i % 2 === 0 ? 'light' : 'dark'} class="!py-16 lg:!py-24">
        <div class:list={[
          'grid grid-cols-1 items-center gap-10 lg:grid-cols-5',
        ]}>
          {/* Número grande */}
          <div class:list={[
            'lg:col-span-2 flex flex-col',
            i % 2 !== 0 ? 'lg:order-2' : 'lg:order-1',
          ]}>
            <span class:list={[
              'font-headline text-[8rem] font-bold leading-none lg:text-[12rem]',
              i % 2 === 0 ? 'text-vinho/10' : 'text-offwhite/10',
            ]}>
              {etapa.letra}
            </span>
            <p class:list={[
              'mt-2 font-body text-xs uppercase tracking-widest',
              i % 2 === 0 ? 'text-caramelo' : 'text-caramelo',
            ]}>
              Etapa {i + 1} de 6
            </p>
          </div>
          {/* Conteúdo */}
          <div class:list={[
            'lg:col-span-3',
            i % 2 !== 0 ? 'lg:order-1' : 'lg:order-2',
          ]}>
            <h2 class="font-headline text-3xl font-bold lg:text-4xl">
              {etapa.nome}
            </h2>
            <p class:list={[
              'mt-1 font-body text-sm uppercase tracking-wider',
              i % 2 === 0 ? 'text-vinho/40' : 'text-offwhite/40',
            ]}>
              {etapa.sub}
            </p>
            <p class="mt-6 font-accent text-xl italic text-caramelo lg:text-2xl">
              "{etapa.frase}"
            </p>
            <p class:list={[
              'mt-4 max-w-lg font-body text-lg',
              i % 2 === 0 ? 'text-vinho/70' : 'text-offwhite/70',
            ]}>
              {etapa.desc}
            </p>
          </div>
        </div>
      </SectionWrapper>
    </Fragment>
  ))}

  <!-- ═══ TRANSIÇÃO VALORES ═══ -->
  <div class="bg-navy py-16 lg:py-24">
    <div class="mx-auto max-w-content px-4 text-center sm:px-6 lg:px-8">
      <p class="font-body text-xs uppercase tracking-[0.3em] text-caramelo">Hexágono Moral</p>
      <h2 class="mt-4 font-headline text-3xl font-bold text-offwhite lg:text-4xl">
        6 valores inegociáveis
      </h2>
      <p class="mt-3 font-body text-offwhite/50">O método é o que fazemos. Os valores são o porquê.</p>

      <div class="mt-12 grid grid-cols-1 gap-px bg-offwhite/10 sm:grid-cols-2 lg:grid-cols-3">
        {valores.map((valor) => (
          <div class="bg-navy p-8 text-left transition-all duration-200 hover:bg-navy/80">
            <h3 class="font-headline text-lg font-bold text-offwhite">{valor.nome}</h3>
            <p class="mt-2 font-body text-sm text-offwhite/50">{valor.mantra}</p>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- ═══ CADARN vs MERCADO — Visual, não tabela ═══ -->
  <SectionWrapper variant="light" class="!py-16 lg:!py-28" id="diferenciais">
    <div class="grid grid-cols-1 items-start gap-12 lg:grid-cols-2">
      <div class="lg:sticky lg:top-24">
        <p class="font-body text-sm uppercase tracking-widest text-caramelo">Por que diferente</p>
        <h2 class="mt-3 font-headline text-3xl font-bold lg:text-4xl">
          Cadarn vs.<br />o que você<br /><span class="font-accent italic text-caramelo">já conhece.</span>
        </h2>
      </div>
      <div class="space-y-6">
        {diferenciais.map((d) => (
          <div class="border-l-2 border-caramelo/30 pl-6">
            <p class="font-headline text-xs font-bold uppercase tracking-wider text-caramelo">{d.aspecto}</p>
            <p class="mt-2 font-body text-vinho/40 line-through">{d.mercado}</p>
            <p class="mt-1 font-headline text-lg font-bold">{d.cadarn}</p>
          </div>
        ))}
      </div>
    </div>
  </SectionWrapper>

  <!-- ═══ CTA FINAL ═══ -->
  <SectionWrapper variant="dark" class="!py-16 lg:!py-24">
    <div class="grid grid-cols-1 items-center gap-12 lg:grid-cols-2">
      <div>
        <h2 class="font-headline text-3xl font-bold lg:text-4xl">
          Quer ver o Método<br />aplicado ao <span class="font-accent italic text-caramelo">seu</span> negócio?
        </h2>
        <p class="mt-4 max-w-md font-body text-lg text-offwhite/60">
          O Scan de Autoridade é a porta de entrada do C.A.D.A.R.N. — diagnóstico gratuito com score de 0 a 100.
        </p>
        <CTABlock variant="hero" class="mt-8 !text-left" />
      </div>
      <div class="flex items-center justify-center">
        <img src="/logo-splash.png" alt="Cadarn Martech" class="h-48 w-48 object-contain opacity-20 lg:h-64 lg:w-64" />
      </div>
    </div>
  </SectionWrapper>
</BaseLayout>
