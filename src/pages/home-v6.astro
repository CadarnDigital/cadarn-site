---
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import { SplashScreenV2 as SplashScreen } from '../components/ui/SplashScreenV2';
import { Button } from '../components/ui/Button';
import { ScrollReveal } from '../components/ui/ScrollReveal';
import { Accordion } from '../components/ui/Accordion';
import { NavDotsV6 } from '../components/ui/NavDotsV6';
import ScrollSection from '../components/ui/ScrollSection.astro';
import VideoPlaceholder from '../components/ui/VideoPlaceholder.astro';
import '../styles/global.css';

const metodoItems = [
  { trigger: 'C', label: 'Clareza', sublabel: 'Scan de Vulnerabilidade', content: 'Não se gerencia o que não se vê. Mapeamos cada vazamento, cada ponto cego, cada risco invisível que drena seu faturamento.' },
  { trigger: 'A', label: 'Arquitetura', sublabel: 'Blueprint Tático', content: 'Desenhar antes de gastar. Processo, funil, DNA da marca — tudo documentado antes de investir um centavo em tráfego.' },
  { trigger: 'D', label: 'Dados & DNA', sublabel: 'Validação + Identidade', content: 'Dados validam a estratégia. DNA codifica seu tom e estética. Juntos, são blindagem contra achismo.' },
  { trigger: 'A', label: 'Ação', sublabel: 'Ofensiva Sincronizada', content: 'Mão na massa com precisão cirúrgica. Cronograma preciso, territórios definidos, execução sem improviso.' },
  { trigger: 'R', label: 'Rastreio', sublabel: 'Tribunal do ROI', content: 'Foco: faturamento e leads qualificados reais. Se não gera faturamento, não conta. Jamais métricas de vaidade.' },
  { trigger: 'N', label: 'Norma', sublabel: 'Lei de Ouro', content: 'Se funcionou, vira lei. O dono sai da operação, o processo fica. Autonomia real — você comanda.' },
];
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Cadarn Martech — Engenharia de Lucro para prestadores de serviço premium" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Cadarn Martech — Marketing · Gestão · Growth</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <style is:inline>
      .splash-cover { position:fixed;inset:0;z-index:9998;background:#0e2a4a; }
    </style>
  </head>
  <body class="flex min-h-screen flex-col">
    <div class="splash-cover" id="splash-cover"></div>
    <SplashScreen client:load />
    <Header />
    <NavDotsV6 client:load />

    <main class="flex-1 pt-16 scroll-snap-container">

      <!-- ═══════════════════════════════════════════════════
           DOBRA 1 — HERO + VÍDEO SAMIRA (conexão/dor)
           ═══════════════════════════════════════════════════ -->
      <ScrollSection id="video" variant="vinho" peek={false} index={0}>
        <div class="flex min-h-screen flex-col items-center pt-2 pb-6">

          <!-- Bloco identidade: logo + nome -->
          <ScrollReveal client:load delay={0.1} direction="none">
            <div class="flex flex-col items-center">
              <img src="/logo-splash.png" alt="Cadarn Martech" style="height:300px;width:auto;display:block;" />
              <span class="-mt-2 font-headline text-2xl font-bold uppercase tracking-[0.35em] text-caramelo sm:text-3xl">Cadarn Martech</span>
              <p class="mt-1 font-headline text-sm uppercase tracking-[0.3em] text-offwhite/50">
                Marketing · Gestão · Growth
              </p>
            </div>
          </ScrollReveal>

          <!-- Tagline -->
          <ScrollReveal client:load delay={0.3} direction="up">
            <h1 class="mt-8 text-center font-headline text-3xl font-bold uppercase tracking-[0.15em] leading-tight text-offwhite sm:text-4xl lg:text-5xl">
              Engenharia de <span class="text-caramelo">Lucro</span>
            </h1>
          </ScrollReveal>


          <!-- Vídeo Samira — grande, protagonista -->
          <ScrollReveal client:load delay={0.7} direction="up" className="mt-10 flex-1 flex items-center w-full">
            <div class="w-full max-w-5xl mx-auto glow-caramelo-lg">
              <VideoPlaceholder label="Vídeo Samira — conexão (30s)" />
            </div>
          </ScrollReveal>

        </div>

        <!-- Background: bússola marca d'água -->
        <Fragment slot="background">
          <div class="pointer-events-none absolute inset-0 opacity-[0.05]" style="background-image:url('/textures/grain.svg');background-size:256px;background-repeat:repeat;mix-blend-mode:multiply;" />
          <!-- Marca d'água bússola -->
          <div class="pointer-events-none absolute inset-0 flex items-center justify-center opacity-[0.05]">
            <img src="/logo-splash.png" alt="" style="height:700px;width:700px;" aria-hidden="true" />
          </div>
        </Fragment>
      </ScrollSection>

      <!-- ═══════════════════════════════════════════════════
           DOBRA 2 — MÉTODO (accordion + números)
           ═══════════════════════════════════════════════════ -->
      <ScrollSection id="metodo" variant="navy" index={1}>
        <div class="flex min-h-screen flex-col justify-center py-16">
          <!-- Header -->
          <ScrollReveal client:load direction="up">
            <div class="flex items-end justify-between">
              <div>
                <p class="font-mono text-xs uppercase tracking-wider text-caramelo/70">O framework proprietário</p>
                <h2 class="mt-2 font-headline text-4xl font-bold lg:text-5xl">
                  <span class="text-caramelo">C.</span>A.<span class="text-caramelo">D.</span>A.<span class="text-caramelo">R.</span>N.
                </h2>
              </div>
              <!-- Números desktop -->
              <div class="hidden items-end gap-8 lg:flex">
                {[
                  { v: '6', l: 'etapas do método' },
                  { v: '7', l: 'dias p/ diagnóstico' },
                  { v: '30', l: 'dias p/ o plano' },
                  { v: '90', l: 'dias p/ autonomia' },
                ].map((n) => (
                  <div class="text-center">
                    <span class="font-mono text-3xl font-bold text-caramelo">{n.v}</span>
                    <p class="font-mono text-[10px] uppercase tracking-wider text-offwhite/40">{n.l}</p>
                  </div>
                ))}
              </div>
            </div>
          </ScrollReveal>

          <!-- Números mobile -->
          <div class="mt-6 flex flex-wrap justify-center gap-8 lg:hidden">
            {[
              { v: '6', l: 'etapas do método' },
              { v: '7', l: 'dias p/ diagnóstico' },
              { v: '30', l: 'dias p/ o plano' },
              { v: '90', l: 'dias p/ autonomia' },
            ].map((n) => (
              <div class="text-center">
                <span class="font-mono text-2xl font-bold text-caramelo">{n.v}</span>
                <p class="font-mono text-[10px] uppercase tracking-wider text-offwhite/40">{n.l}</p>
              </div>
            ))}
          </div>

          <!-- Accordion -->
          <div class="mt-10">
            <Accordion client:load items={metodoItems} />
          </div>

          <!-- CTA discreto -->
          <div class="mt-8 flex justify-center">
            <a href="/scan" class="shimmer inline-block border border-caramelo/20 px-8 py-3 font-headline text-sm uppercase tracking-widest text-caramelo transition-colors duration-200 hover:border-caramelo">
              Fazer meu Scan de Autoridade →
            </a>
          </div>
        </div>

        <!-- Background: bússola marca d'água -->
        <Fragment slot="background">
          <div class="pointer-events-none absolute inset-0 flex items-center justify-center opacity-[0.04]">
            <img src="/logo-splash.png" alt="" style="height:750px;width:750px;" aria-hidden="true" />
          </div>
        </Fragment>
      </ScrollSection>

      <!-- ═══════════════════════════════════════════════════
           DOBRA 3 — TRÍADE (foto + pilares)
           ═══════════════════════════════════════════════════ -->
      <ScrollSection id="triade" variant="offwhite" index={2}>
        <div class="flex min-h-screen items-center py-16">
          <div class="grid w-full grid-cols-1 items-center gap-12 lg:grid-cols-2">
            <!-- FOTO: Tríade -->
            <ScrollReveal client:load direction="left">
              <div class="relative aspect-[4/5] overflow-hidden border-2 border-dashed border-caramelo/30">
                <div class="absolute inset-0 gradient-mesh" />
                <div class="absolute inset-0 flex flex-col items-center justify-center gap-3 p-6">
                  <div class="flex h-20 w-20 items-center justify-center border border-caramelo/40 rounded-full">
                    <svg class="h-10 w-10 text-caramelo/60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0" />
                    </svg>
                  </div>
                  <span class="font-mono text-sm uppercase tracking-wider text-navy/50">📷 Foto Tríade</span>
                  <span class="font-body text-xs text-navy/30">Fabiano · Samira · Gui</span>
                </div>
              </div>
            </ScrollReveal>

            <!-- Pilares -->
            <ScrollReveal client:load delay={0.2} direction="right">
              <div>
                <p class="font-mono text-xs uppercase tracking-wider text-caramelo">Quem faz acontecer</p>
                <h2 class="mt-3 font-headline text-3xl font-bold lg:text-4xl">
                  Três forças.<br />Um <span class="font-accent italic text-caramelo">sistema.</span>
                </h2>

                <div class="mt-10 space-y-6">
                  {[
                    { pilar: 'Marketing', desc: 'Posicionamento, conteúdo e autoridade que gera demanda qualificada.', borda: 'border-l-vinho' },
                    { pilar: 'Gestão', desc: 'Processos, métricas e rotinas que transformam sua operação em máquina.', borda: 'border-l-navy' },
                    { pilar: 'Growth', desc: 'Funil, conversão e escala. Cada gargalo identificado.', borda: 'border-l-caramelo' },
                  ].map((item) => (
                    <div class={`border-l-4 pl-6 ${item.borda}`}>
                      <h3 class="font-headline text-xl font-bold">{item.pilar}</h3>
                      <p class="mt-1 font-body text-sm text-vinho/60">{item.desc}</p>
                    </div>
                  ))}
                </div>

              </div>
            </ScrollReveal>
          </div>
        </div>

        <!-- Background: bússola marca d'água -->
        <Fragment slot="background">
          <div class="pointer-events-none absolute inset-0 flex items-center justify-center opacity-[0.035]">
            <img src="/logo-splash.png" alt="" style="height:650px;width:650px;" aria-hidden="true" />
          </div>
        </Fragment>
      </ScrollSection>

      <!-- ═══════════════════════════════════════════════════
           DOBRA 4 — SCAN CADARN (vídeo demo + CTA + newsletter)
           ═══════════════════════════════════════════════════ -->
      <ScrollSection id="cta" variant="navy" index={3}>
        <div class="flex min-h-screen flex-col items-center justify-center py-16">

          <!-- Logo com glow -->
          <ScrollReveal client:load direction="up">
            <div class="glow-caramelo mb-6">
              <img src="/logo-splash.png" alt="Cadarn Martech" class="h-16 w-16 object-contain" />
            </div>
          </ScrollReveal>

          <!-- Headline -->
          <ScrollReveal client:load delay={0.1} direction="up">
            <h2 class="text-center font-headline text-3xl font-bold text-offwhite lg:text-4xl xl:text-5xl">
              Scan <span class="text-caramelo">Cadarn</span>
            </h2>
            <p class="mx-auto mt-3 max-w-md text-center font-body text-base text-offwhite/60">
              Seu marketing analisado em 4 pilares. Score de 0 a 100. Gratuito.
            </p>
          </ScrollReveal>

          <!-- Vídeo demo Samira + Gui -->
          <ScrollReveal client:load delay={0.3} direction="up">
            <div class="mt-8 w-full max-w-3xl glow-caramelo-lg">
              <VideoPlaceholder label="Vídeo Samira + Gui — demo do Scan" />
            </div>
          </ScrollReveal>

          <!-- CTA principal -->
          <ScrollReveal client:load delay={0.5} direction="up">
            <div class="mt-8 text-center">
              <Button variant="secondary" size="lg" href="/scan">Fazer meu Scan de Autoridade</Button>
              <p class="mt-3 font-mono text-xs text-offwhite/40">Grátis · 5 minutos · Sem compromisso</p>
              <p class="mt-1 font-body text-sm text-offwhite/30">Cada semana sem método é dinheiro que não volta.</p>
            </div>
          </ScrollReveal>

        </div>

        <!-- Background: tech grid + bússola -->
        <Fragment slot="background">
          <div class="pointer-events-none absolute inset-0 tech-grid opacity-[0.03]" />
          <div class="pointer-events-none absolute inset-0 flex items-center justify-center opacity-[0.04]">
            <img src="/logo-splash.png" alt="" style="height:700px;width:700px;" aria-hidden="true" />
          </div>
        </Fragment>
      </ScrollSection>

    </main>
    <Footer />
    <script>sessionStorage.removeItem('cadarn_splash_shown');</script>
  </body>
</html>
