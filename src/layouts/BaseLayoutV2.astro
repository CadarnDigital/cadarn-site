---
/**
 * BaseLayoutV2 — layout da versao 2 "premium tech" do site: NAVY-dominante.
 * Dark-dominante. Lenis (scroll com inercia) via SmoothScrollProvider.
 * NAO usa <ClientRouter> (conflito documentado com Lenis — Astro #12725).
 * noindex enquanto for pagina de validacao.
 * Reusa Header/Footer da v1 (read-only, apenas importados).
 *
 * Cor: importa v-shared.css (utilitarias/motion comuns) + tokens-v2.css (NAVY).
 * A v3 (vinho) usa o mesmo conjunto de componentes trocando so o token file.
 */
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import { SmoothScrollProvider } from '../components/v2/SmoothScrollProvider';
import '../styles/global.css';
import '../styles/v-shared.css';
import '../styles/tokens-v2.css';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Cadarn Martech — Engenharia de Lucro. Marketing · Gestão · Growth.',
} = Astro.props;

const fullTitle = `${title} | Cadarn Martech`;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="noindex" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{fullTitle}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <slot name="head" />
  </head>
  <body class="flex min-h-screen flex-col bg-surface-abyss text-on-dark-body antialiased">
    <SmoothScrollProvider client:load />
    <Header />
    <main class="flex-1 pt-16">
      <slot />
    </main>
    <Footer />
  </body>
</html>
