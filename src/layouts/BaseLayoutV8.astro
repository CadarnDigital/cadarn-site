---
/**
 * BaseLayoutV8 â€” layout da v8 "engrenagemâ†’LOGO Cadarn" (storyboard 2026-06-21 evoluĂ­do).
 * CĂ³pia de BaseLayoutV7 com:
 *   1. tokens-v8.css (mesma paleta, arquivo isolado)
 *   2. #v8-intro-cover â€” div estĂ¡tico visĂ­vel desde o primeiro paint (SSR).
 *      Elimina o bug da v6 ("site aparece antes da abertura").
 *      O IntroRitualV8 remove este div no mount e assume o controle do overlay.
 * noindex enquanto for pĂ¡gina de validaĂ§Ă£o.
 */
import Footer from '../components/layout/Footer.astro';
import { HeaderV6 } from '../components/v6/HeaderV6';
import { SmoothScrollProvider } from '../components/v6/SmoothScrollProvider';
import '../styles/global.css';
import '../styles/v-shared.css';
import '../styles/tokens-v8.css';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Cadarn Martech â€” Engenharia de Lucro. Marketing Â· GestĂ£o Â· Growth.',
} = Astro.props;

const fullTitle = `${title} | Cadarn Martech`;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="noindex" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{fullTitle}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <!--
      Cover estĂ¡tico (SSR) â€” visĂ­vel desde o primeiro paint, antes do React hidratar.
      Previne o flash de conteĂºdo que afetou a v6 (site aparecia antes do overlay montar).
      O IntroRitualV8 remove este elemento no useEffect do mount.
    -->
    <style>
      #v8-intro-cover {
        position: fixed;
        inset: 0;
        z-index: 9998;
        background: #5e0f0b;
        pointer-events: none;
      }
    </style>

    <slot name="head" />
  </head>
  <body class="v-eval flex min-h-screen flex-col bg-surface-abyss text-on-dark-body antialiased">
    <div id="v8-intro-cover" aria-hidden="true"></div>

    <SmoothScrollProvider client:load />
    <HeaderV6 client:load />
    <main class="flex-1 pt-16">
      <slot />
    </main>
    <Footer />
  </body>
</html>
