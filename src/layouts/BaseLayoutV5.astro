---
/**
 * BaseLayoutV5 — layout da versao 5: cópia da v4 "premium tech cinematografica"
 * (VINHO-dominante) com UMA única mudança de página: a abertura passa a ser o
 * IntroRitual contemplativo em torno da bússola (substitui o CurtainIntro).
 *  - tokens-v5.css (cópia de tokens-v4.css; vinho + aditivos de movimento)
 *  - componentes próprios de src/components/v5/* (isolados; não afetam v2/v3/v4)
 *  - SmoothScrollProvider da v5 (respeita EVALUATION_MODE)
 *  - HeaderV4 (cópia em components/v5) com scroll-spy
 *  - classe .v-eval no <body> para forçar o ticker mesmo com reduced-motion
 * Reusa Footer da v1 (read-only). noindex enquanto for pagina de validacao.
 */
import Footer from '../components/layout/Footer.astro';
import { HeaderV4 } from '../components/v5/HeaderV4';
import { SmoothScrollProvider } from '../components/v5/SmoothScrollProvider';
import '../styles/global.css';
import '../styles/v-shared.css';
import '../styles/tokens-v5.css';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Cadarn Martech — Engenharia de Lucro. Marketing · Gestão · Growth.',
} = Astro.props;

const fullTitle = `${title} | Cadarn Martech`;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="noindex" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{fullTitle}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <slot name="head" />
  </head>
  <body class="v-eval flex min-h-screen flex-col bg-surface-abyss text-on-dark-body antialiased">
    <SmoothScrollProvider client:load />
    <HeaderV4 client:load />
    <main class="flex-1 pt-16">
      <slot />
    </main>
    <Footer />
  </body>
</html>
