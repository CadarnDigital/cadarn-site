---
/**
 * BaseLayoutV4 — layout da versao 4 "premium tech cinematografica": VINHO-dominante.
 * Cópia de BaseLayoutV3 com:
 *  - tokens-v4.css (vinho + aditivos de movimento da v4)
 *  - componentes próprios de src/components/v4/* (isolados; não afetam v2/v3)
 *  - SmoothScrollProvider da v4 (respeita EVALUATION_MODE)
 *  - HeaderV4 com scroll-spy (substitui o Header v1 read-only nesta versão)
 *  - classe .v-eval no <body> para forçar o ticker mesmo com reduced-motion
 * Reusa Footer da v1 (read-only). noindex enquanto for pagina de validacao.
 */
import Footer from '../components/layout/Footer.astro';
import { HeaderV4 } from '../components/v4/HeaderV4';
import { SmoothScrollProvider } from '../components/v4/SmoothScrollProvider';
import '../styles/global.css';
import '../styles/v-shared.css';
import '../styles/tokens-v4.css';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Cadarn Martech — Engenharia de Lucro. Marketing · Gestão · Growth.',
} = Astro.props;

const fullTitle = `${title} | Cadarn Martech`;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="noindex" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{fullTitle}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <slot name="head" />
  </head>
  <body class="v-eval flex min-h-screen flex-col bg-surface-abyss text-on-dark-body antialiased">
    <SmoothScrollProvider client:load />
    <HeaderV4 client:load />
    <main class="flex-1 pt-16">
      <slot />
    </main>
    <Footer />
  </body>
</html>
